APP_NAME="Tips From The Garden"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://tips-from-the-garden.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=tips-from-the-garden
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database
CACHE_STORE=database

FILESYSTEM_DISK=local

# Mail — "log" writes emails to storage/logs for local dev.
# For real delivery via Postmark SMTP, set:
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.postmarkapp.com
#   MAIL_PORT=587
#   MAIL_USERNAME / MAIL_PASSWORD = your Postmark Server API Token (same value for both)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@tipsfromthegarden.test"
MAIL_FROM_NAME="${APP_NAME}"
# Optional: replies go here (an address that forwards to a real inbox) while
# MAIL_FROM_ADDRESS stays send-only.
MAIL_REPLY_TO_ADDRESS=
MAIL_REPLY_TO_NAME="${APP_NAME}"

# --- Pipeline drivers ---------------------------------------
# transcriber: whisper_cpp | fake
# writer:      ollama | anthropic | fake
TRANSCRIBER_DRIVER=whisper_cpp
WRITER_DRIVER=ollama

# whisper.cpp (brew install whisper-cpp ffmpeg)
WHISPER_BINARY=/opt/homebrew/bin/whisper-cli
WHISPER_MODEL=/opt/homebrew/share/whisper-cpp/ggml-large-v3-turbo.bin
FFMPEG_BINARY=/opt/homebrew/bin/ffmpeg

# Ollama (local generation tier)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:32b

# Anthropic (frontier generation tier)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# --- Inbound email (Postmark) --------------------------------
# Set the inbound webhook URL in Postmark to:
#   https://<your-tunnel-or-domain>/webhooks/postmark?token=<POSTMARK_INBOUND_TOKEN>
POSTMARK_INBOUND_TOKEN=
# The address gardeners email memos to (shown on the homepage). Falls back to
# memos@<APP_URL host> when unset — set it when the web host can't carry mail.
INBOUND_EMAIL_ADDRESS=

# Twill admin lives at /admin
ADMIN_APP_PATH=admin
