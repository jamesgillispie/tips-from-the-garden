APP_NAME="Tips From The Garden"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://tips-from-the-garden.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=tips-from-the-garden
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database
CACHE_STORE=database

FILESYSTEM_DISK=local

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Mail — "log" writes emails to storage/logs for local dev.
# For real delivery via Postmark, use the native transport:
#   MAIL_MAILER=postmark
#   POSTMARK_TOKEN=your-postmark-server-api-token   (set below)
# …or Postmark over SMTP:
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.postmarkapp.com
#   MAIL_PORT=587
#   MAIL_USERNAME / MAIL_PASSWORD = your Postmark Server API Token (same value for both)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@tipsfromthegarden.test"
MAIL_FROM_NAME="${APP_NAME}"
# Optional: replies go here (an address that forwards to a real inbox) while
# MAIL_FROM_ADDRESS stays send-only.
MAIL_REPLY_TO_ADDRESS=
MAIL_REPLY_TO_NAME="${APP_NAME}"
# Postmark Server API Token — outbound transactional mail when MAIL_MAILER=postmark.
POSTMARK_TOKEN=

# --- Pipeline drivers ---------------------------------------
# transcriber: whisper_cpp | fake
# writer:      ollama | anthropic | fake
TRANSCRIBER_DRIVER=whisper_cpp
WRITER_DRIVER=ollama

# whisper.cpp (brew install whisper-cpp ffmpeg)
WHISPER_BINARY=/opt/homebrew/bin/whisper-cli
WHISPER_MODEL=/opt/homebrew/share/whisper-cpp/ggml-large-v3-turbo.bin
FFMPEG_BINARY=/opt/homebrew/bin/ffmpeg

# Ollama (local generation tier)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:32b

# Anthropic (frontier generation tier)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# --- Photos ---------------------------------------------------
# Photos captured alongside a recording are re-encoded on intake (EXIF
# stripped, originals discarded — docs/adr/0003) and served only through the
# app's token-gated route (docs/adr/0002). Production stores them in a
# private S3 bucket: set PHOTO_DISK=s3 and fill in the AWS keys. Local dev
# can leave PHOTO_DISK=local.
PHOTO_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Inbound email (Postmark) --------------------------------
# Set the inbound webhook URL in Postmark to:
#   https://<your-tunnel-or-domain>/webhooks/postmark?token=<POSTMARK_INBOUND_TOKEN>
POSTMARK_INBOUND_TOKEN=
# The address gardeners email memos to (shown on the homepage). Falls back to
# memos@<APP_URL host> when unset — set it when the web host can't carry mail.
INBOUND_EMAIL_ADDRESS=

# --- Cloudflare Turnstile (guards the sign-in form) ----------
# Create a widget at dash.cloudflare.com → Turnstile, add your domain (and
# localhost for dev). Leave BOTH blank to fall back to Cloudflare's always-pass
# TEST keys, which is fine for local dev. Set real keys in production.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Twill admin lives at /admin
ADMIN_APP_PATH=admin
