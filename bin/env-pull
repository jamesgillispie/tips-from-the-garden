#!/usr/bin/env bash
# Regenerate .env from the 1Password Environment (single source of truth).
# Change a variable in 1Password, then run: composer env:pull
set -euo pipefail
cd "$(dirname "$0")/.."
# shellcheck disable=SC1091
source ./.op-env
# Build into a temp file first; only replace .env if the read fully succeeds, so
# a failed/cancelled auth never clobbers an existing .env.
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT
{
  echo "# Generated by bin/env-pull from 1Password environment $OP_ENVIRONMENT_ID"
  echo "# Do not edit by hand — change the variable in 1Password, then: composer env:pull"
  # op outputs raw KEY=value; quote any value containing whitespace or '#' so
  # values like APP_NAME="Tips From The Garden" are valid dotenv.
  op environment read "$OP_ENVIRONMENT_ID" --account "$OP_ACCOUNT" \
    | perl -pe 'if (/^([A-Za-z_]\w*)=(.*)$/) { my ($k,$v)=($1,$2); if ($v !~ /^".*"$/ && $v =~ /[\s#]/) { $v =~ s/\\/\\\\/g; $v =~ s/"/\\"/g; $_ = "$k=\"$v\"\n"; } }'
} > "$tmp"
if [ -f .env ]; then cp .env .env.backup; fi
mv "$tmp" .env
echo "Wrote .env ($(grep -c '=' .env) vars) from 1Password environment $OP_ENVIRONMENT_ID"
